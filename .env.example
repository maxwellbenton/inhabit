# Postgres connection string (Vercel Postgres gives you this in the project's Storage tab)
DATABASE_URL="postgres://user:password@host:5432/dbname?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth client (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Comma-separated list of emails allowed to sign in (e.g. "you@gmail.com,partner@gmail.com").
# Each gets their own private reminders/work blocks/settings — data is isolated
# per Google account at the database level. Leave blank to allow any Google account
# (not recommended; isolation still applies, but anyone can create an account).
ALLOWED_EMAIL="maxwellbenton@gmail.com"

# Vercel Blob (Vercel project → Storage → Blob → create store, copy token)
BLOB_READ_WRITE_TOKEN=""
