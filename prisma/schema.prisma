generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Reminder {
  id        String   @id @default(cuid())
  userEmail String // owning account — every query/mutation is scoped to this
  title     String
  body      String   @default("")
  imageUrl  String   @default("")
  videoUrl  String   @default("")
  time      String // "HH:MM", 24h
  days      Int[] // 0=Sun .. 6=Sat
  color     String   @default("cyan")
  enabled   Boolean  @default(true)
  skipDates String[] @default([]) // "YYYY-MM-DD" dates to silence a single occurrence
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userEmail])
}

model WorkBlock {
  id        String   @id @default(cuid())
  userEmail String // owning account — every query/mutation is scoped to this
  label     String
  start     String // "HH:MM"
  end       String // "HH:MM"
  workMin   Int      @default(25)
  breakMin  Int      @default(5)
  days      Int[]
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userEmail])
}

// One row per account — each signed-in user gets their own settings.
model AppSettings {
  userEmail       String @id
  takeoverSeconds Int    @default(90)
}
